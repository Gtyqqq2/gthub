local monsters = {}

local function updateMonsters()
    local new = {}

    for _, m in pairs(workspace:GetDescendants()) do
        local h = m:FindFirstChildOfClass("Humanoid")
        local r = m:FindFirstChild("HumanoidRootPart")

        if h and r then
            table.insert(new, m)
        end
    end

    monsters = new
end

task.spawn(function()
    while true do
        if enabled then
            updateMonsters()
        end
        task.wait(0.7)
    end
end)

task.spawn(function()
    local lastHit = 0
    local index = 1

    while true do
        if enabled and hrp then
            RunService.Heartbeat:Wait()

            local now = tick()

            if now - lastHit >= speed then
                lastHit = now

                local hrpPos = hrp.Position
                local rangeSq = range * range
                local list = monsters

                if #list > 0 then
                    for i = 1, 10 do
                        local m = list[index]

                        if not m then break end

                        local h = m:FindFirstChildOfClass("Humanoid")
                        local r = m:FindFirstChild("HumanoidRootPart")

                        if h and r and h.Health > 0 then
                            local diff = hrpPos - r.Position
                            if (diff.X*diff.X + diff.Y*diff.Y + diff.Z*diff.Z) <= rangeSq then
                                remote:FireServer("DamToMonster", m, {damtype = "normal"})
                            end
                        end

                        index += 1
                        if index > #list then
                            index = 1
                        end
                    end
                end
            end
        else
            RunService.Heartbeat:Wait()
        end
    end
end)

