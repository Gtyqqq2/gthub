local startTime = tick()

local function formatTime(sec)
    local d = math.floor(sec / 86400)
    sec = sec % 86400

    local h = math.floor(sec / 3600)
    sec = sec % 3600

    local m = math.floor(sec / 60)
    local s = sec % 60

    if d > 0 then
        return d.."d "..h.."h "..m.."m "..s.."s"
    elseif h > 0 then
        return h.."h "..m.."m "..s.."s"
    elseif m > 0 then
        return m.."m "..s.."s"
    else
        return s.."s"
    end
end

